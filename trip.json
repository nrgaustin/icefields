
:root{--ink:#122235;--muted:#667487;--paper:#f4f7f8;--card:#fff;--line:#d8e1e6;--accent:#176a58;--soft:#e5f1ed;--deep:#0b2923;--shadow:0 20px 55px rgba(20,45,55,.10)}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,"Segoe UI",sans-serif;color:var(--ink);background:var(--paper)}button,input,select{font:inherit}
.hero{min-height:52vh;display:grid;align-items:end;background:linear-gradient(180deg,rgba(5,20,25,.08),rgba(5,20,25,.82)),url("../photos/large/IMG_0071.jpg") center/cover}.hero-inner,.wrap{width:min(1280px,calc(100% - 32px));margin:auto}.hero-inner{padding:90px 0 52px;color:#fff}
.kicker,.eyebrow{text-transform:uppercase;letter-spacing:.16em;font-weight:850;font-size:.76rem}.eyebrow{color:var(--accent)}h1,h2,h3{font-family:Georgia,"Times New Roman",serif;letter-spacing:-.035em}h1{font-size:clamp(3rem,7vw,6.2rem);line-height:.9;margin:12px 0 18px;max-width:900px}h2{font-size:clamp(2rem,4vw,3.5rem);margin:8px 0}.hero p,.lede{line-height:1.65}.hero p{font-size:1.12rem;max-width:780px}.lede{color:var(--muted);margin:0}
.chips{display:flex;flex-wrap:wrap;gap:9px;margin-top:22px}.chip{border:1px solid rgba(255,255,255,.35);background:rgba(255,255,255,.14);padding:8px 12px;border-radius:999px;font-weight:750}
.view-tabs{position:sticky;top:0;z-index:900;background:rgba(244,247,248,.95);backdrop-filter:blur(9px);border-bottom:1px solid var(--line)}.view-tabs-inner{width:min(1280px,calc(100% - 32px));margin:auto;display:flex;gap:8px;padding:10px 0}.view-tab{border:1px solid var(--line);background:#fff;border-radius:999px;padding:9px 15px;cursor:pointer;font-weight:800}.view-tab.active{background:var(--accent);border-color:var(--accent);color:#fff}
.view-panel[hidden]{display:none}.section{padding:64px 0}.section-head{display:grid;grid-template-columns:.9fr 1.1fr;gap:42px;align-items:end;margin-bottom:26px}
.loading{background:#fff;border:1px solid var(--line);border-radius:18px;padding:18px 20px;margin-bottom:16px;display:flex;align-items:center;gap:14px}.spinner{width:20px;height:20px;border:3px solid var(--line);border-top-color:var(--accent);border-radius:50%;animation:spin .9s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}
.explorer{background:#fff;border:1px solid var(--line);border-radius:22px;overflow:hidden;box-shadow:var(--shadow)}.top-grid{display:grid;grid-template-columns:minmax(0,1.6fr) minmax(340px,.76fr);min-height:630px}
.map-wrap{position:relative;min-height:630px}.map{height:100%;min-height:630px;background:#e6ecee}.map-view-controls{position:absolute;z-index:500;right:14px;top:14px;display:flex;gap:7px;align-items:flex-start}.map-view-buttons{display:flex;gap:5px;background:rgba(255,255,255,.94);border:1px solid var(--line);padding:6px;border-radius:12px}.map-view-buttons button{border:1px solid var(--line);background:#fff;border-radius:8px;padding:7px 10px;cursor:pointer;font-weight:700;font-size:.82rem}.map-view-buttons button.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.map-play{border:2px solid #fff;background:var(--accent);color:#fff;border-radius:999px;padding:10px 15px;cursor:pointer;font-weight:850;box-shadow:0 5px 18px rgba(0,0,0,.25)}.map-play small{display:block;font-size:.62rem;font-weight:600;opacity:.82}
.basemap-control{position:absolute;z-index:500;right:14px;top:72px;background:rgba(255,255,255,.95);border:1px solid var(--line);border-radius:10px;padding:7px}.basemap-control select{border:0;background:transparent;font-size:.82rem;font-weight:700;color:var(--ink)}
.side{padding:20px;display:flex;flex-direction:column;gap:14px;min-width:0}.now{display:flex;justify-content:space-between;gap:12px}.place{font-family:Georgia,serif;font-size:1.75rem}.subtle{color:var(--muted);font-size:.84rem}.badge{background:var(--accent);color:#fff;border-radius:999px;padding:7px 11px;font-weight:800;height:max-content}
.metric-context{display:flex;gap:6px;flex-wrap:wrap}.context-btn{border:1px solid var(--line);background:#fff;padding:6px 9px;border-radius:999px;cursor:pointer;font-size:.78rem}.context-btn.active{background:var(--soft);border-color:var(--accent);color:var(--accent);font-weight:800}
.metric-gauges{display:grid;gap:9px}.gauge-row{display:grid;grid-template-columns:78px minmax(0,1fr) 82px;gap:10px;align-items:center}.gauge-label{font-size:.82rem;color:var(--muted);font-weight:700}.gauge-value{text-align:right;font-weight:850;font-size:1rem;font-variant-numeric:tabular-nums}.gauge-track{position:relative;height:13px;border-radius:999px;background:#edf1f3;overflow:visible}.gauge-fill{position:absolute;left:0;top:0;bottom:0;border-radius:999px;background:linear-gradient(90deg,var(--soft),var(--accent));min-width:2px}.gauge-zero{position:absolute;top:-3px;bottom:-3px;width:1px;background:#8a97a5;opacity:.8}.gauge-dot{position:absolute;top:50%;width:15px;height:15px;border:3px solid #fff;border-radius:50%;background:var(--accent);box-shadow:0 1px 5px #0005;transform:translate(-50%,-50%)}.gauge-scale{grid-column:2;display:flex;justify-content:space-between;color:var(--muted);font-size:.65rem;margin-top:-7px}
.photo-panel{position:relative;min-height:245px;border-radius:16px;overflow:hidden;background:#e5eaec;display:grid;place-items:center}.photo-panel img{width:100%;height:100%;min-height:245px;object-fit:cover}.photo-meta{position:absolute;left:0;right:0;bottom:0;padding:38px 13px 12px;background:linear-gradient(transparent,rgba(0,0,0,.78));color:#fff;font-size:.82rem}.photo-meta strong{display:block}.photo-empty{padding:28px;text-align:center;color:var(--muted)}.photo-strip{display:flex;gap:7px;overflow:auto;padding-bottom:4px}.photo-thumb{width:70px;height:54px;flex:0 0 70px;border:2px solid transparent;padding:0;border-radius:9px;overflow:hidden;cursor:pointer;background:#ddd}.photo-thumb.active{border-color:var(--accent)}.photo-thumb img{width:100%;height:100%;object-fit:cover}
.timeline-section{border-top:1px solid var(--line);padding:18px 20px 22px}.timeline-head{display:flex;justify-content:space-between;gap:20px;margin-bottom:8px}.timeline-head span{color:var(--muted)}input[type=range]{width:100%;accent-color:var(--accent)}
.timeline-ribbons{position:relative;height:20px;margin:4px 0 6px}.stage-ribbon{height:9px;border-radius:999px;overflow:hidden;display:flex;background:#edf1f3}.stage-ribbon span{height:100%}.event-ribbon{position:absolute;inset:11px 0 0}.event-mark{position:absolute;transform:translateX(-50%);border:0;padding:0;cursor:pointer;width:8px;height:8px;border-radius:50%;background:#111}
.photo-film{position:relative;height:48px;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:#f7f9fa;margin:7px 0 10px;overflow:hidden}.film-photo{position:absolute;top:5px;width:44px;height:36px;border:2px solid #fff;border-radius:6px;padding:0;overflow:hidden;background:#ddd;cursor:pointer;transform:translateX(-50%);box-shadow:0 1px 4px #0004;transition:transform .15s,z-index .15s}.film-photo:hover,.film-photo.active{transform:translateX(-50%) scale(1.35);z-index:20;border-color:var(--accent)}.film-photo img{width:100%;height:100%;object-fit:cover}.film-cursor{position:absolute;top:0;bottom:0;width:2px;background:#111;pointer-events:none;z-index:30}
.controls{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-top:10px}.btn{border:1px solid var(--line);background:#fff;border-radius:10px;padding:8px 12px;cursor:pointer;font-weight:750}.btn.primary{background:var(--accent);color:#fff;border-color:var(--accent)}
.chart-controls{display:flex;gap:7px;flex-wrap:wrap;margin:16px 0 9px}.chart-toggle{border:1px solid var(--line);background:#fff;border-radius:999px;padding:6px 10px;cursor:pointer;font-size:.8rem}.chart-toggle.active{background:var(--soft);border-color:var(--accent);color:var(--accent);font-weight:800}.charts{display:grid;gap:8px}.chart-row{display:grid;grid-template-columns:92px minmax(0,1fr) 82px;align-items:center;gap:8px;min-height:66px}.chart-name{font-size:.82rem;font-weight:800}.chart-name span{display:block;color:var(--muted);font-weight:500;font-size:.7rem}.chart-value{text-align:right;font-weight:800;font-variant-numeric:tabular-nums}.chart-canvas{width:100%;height:66px;border-radius:8px;background:#f7f9fa;cursor:crosshair;display:block}
.event-card{background:var(--soft);border:1px solid #b9d7ce;border-radius:13px;padding:12px}.event-card strong{display:block}.event-card p{margin:5px 0 0;color:#36554d;font-size:.84rem;line-height:1.4}
.journal-grid{display:grid;gap:24px}.journal-day{background:#fff;border:1px solid var(--line);border-radius:20px;overflow:hidden;box-shadow:0 12px 32px rgba(20,45,55,.07)}.journal-day-grid{display:grid;grid-template-columns:minmax(280px,.85fr) minmax(0,1.15fr)}.journal-photo{min-height:360px;background:#e4e9eb}.journal-photo img{width:100%;height:100%;min-height:360px;object-fit:cover}.journal-copy{padding:28px}.journal-day-title{display:flex;justify-content:space-between;gap:18px;align-items:flex-start}.journal-day-title h3{font-size:2.2rem;margin:0}.journal-metrics{display:flex;flex-wrap:wrap;gap:8px;margin:18px 0}.journal-metric{background:var(--soft);border-radius:999px;padding:7px 10px;color:#31554b;font-size:.82rem;font-weight:750}.journal-text{color:var(--muted);line-height:1.7}.journal-placeholder{border-left:3px solid var(--accent);padding-left:14px;font-style:italic}.journal-gallery{display:flex;gap:8px;overflow:auto;margin-top:18px}.journal-gallery img{width:100px;height:74px;object-fit:cover;border-radius:9px}
.summary-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.summary-card{background:#fff;border:1px solid var(--line);border-radius:15px;padding:16px}.summary-card strong{display:block;font-size:1.35rem}.summary-card span{color:var(--muted);font-size:.85rem}footer{background:var(--deep);color:rgba(255,255,255,.72);padding:27px;text-align:center}
@media(max-width:980px){.section-head{grid-template-columns:1fr}.top-grid{grid-template-columns:1fr}.map-wrap,.map{min-height:520px}.journal-day-grid{grid-template-columns:1fr}.summary-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:580px){.hero{min-height:65vh}.map-wrap,.map{min-height:430px}.side{padding:15px}.gauge-row{grid-template-columns:68px minmax(0,1fr) 70px}.chart-row{grid-template-columns:72px minmax(0,1fr) 68px}.summary-grid{grid-template-columns:1fr 1fr}.timeline-head{flex-direction:column;gap:2px}.map-view-controls{right:8px;top:8px;flex-direction:column;align-items:flex-end}.basemap-control{right:8px;top:112px}}
